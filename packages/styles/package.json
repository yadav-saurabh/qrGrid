{
  "name": "@qrgrid/styles",
  "version": "1.3.3",
  "type": "module",
  "homepage": "https://www.qrgrid.dev/",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "private": false,
  "description": "The Ultimate Customizable QR Code JavaScript Library QR Grid Common Web Styling library",
  "license": "MIT",
  "bugs": "https://github.com/yadav-saurabh/qrgrid/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/yadav-saurabh/qrgrid",
    "directory": "packages/styles"
  },
  "keywords": [
    "qr",
    "qrgrid",
    "styling",
    "react",
    "preact",
    "vue",
    "server",
    "angular"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./common": "./src/common.ts",
    "./canvas": "./src/canvas/index.ts",
    "./canvas/styles": "./src/canvas/styles.ts",
    "./canvas/utils": "./src/canvas/utils.ts",
    "./svg": "./src/svg/index.ts",
    "./svg/styles": "./src/svg/styles.ts",
    "./svg/utils": "./src/svg/utils.ts"
  },
  "scripts": {
    "build": "rimraf ./dist && rollup -c && node ../../scripts/build-pkg.mjs",
    "type-check": "tsc --noEmit",
    "tsc:build": "tsc -b",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@qrgrid/core": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@rollup/plugin-typescript": "catalog:",
    "eslint": "catalog:",
    "globals": "^17.3.0",
    "typescript-eslint": "catalog:",
    "rimraf": "catalog:",
    "rollup": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "/dist"
  ]
}
