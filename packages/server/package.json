{
  "name": "@qrgrid/server",
  "version": "1.0.0",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "type": "module",
  "homepage": "https://www.qrgrid.dev/",
  "private": false,
  "description": "The Ultimate Customizable QR Code JavaScript Library",
  "license": "MIT",
  "bugs": "https://github.com/yadav-saurabh/qrgrid/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/yadav-saurabh/qrgrid",
    "directory": "packages/server"
  },
  "keywords": [
    "qr",
    "qrGrid",
    "server",
    "styling"
  ],
  "scripts": {
    "build": "rimraf ./dist && rollup -c && node ../../scripts/build-pkg.mjs",
    "type-check": "tsc --noEmit",
    "tsc:build": "tsc -b"
  },
  "dependencies": {
    "@qrgrid/core": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "catalog:",
    "@rollup/plugin-typescript": "catalog:",
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "rollup": "catalog:",
    "tslib": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "/dist"
  ]
}
