{
  "name": "@qrgrid/angular",
  "version": "1.1.2",
  "type": "module",
  "homepage": "https://www.qrgrid.dev/",
  "private": false,
  "description": "The Ultimate Customizable QR Code JavaScript Library",
  "license": "MIT",
  "bugs": "https://github.com/yadav-saurabh/qrgrid/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/yadav-saurabh/qrgrid",
    "directory": "packages/angular"
  },
  "keywords": [
    "qr",
    "qrGrid",
    "canvas",
    "svg",
    "styling",
    "angular"
  ],
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./dist/types/qrgrid-angular.d.ts",
      "default": "./dist/fesm2022/qrgrid-angular.mjs"
    },
    "./canvas": {
      "types": "./dist/types/qrgrid-angular-src-canvas.d.ts",
      "default": "./dist/fesm2022/qrgrid-angular-src-canvas.mjs"
    },
    "./svg": {
      "types": "./dist/types/qrgrid-angular-src-svg.d.ts",
      "default": "./dist/fesm2022/qrgrid-angular-src-svg.mjs"
    }
  },
  "scripts": {
    "build": "ng build && node ../../scripts/build-pkg.mjs",
    "ng": "ng",
    "start": "ng serve",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "peerDependencies": {
    "@angular/core": "catalog:"
  },
  "dependencies": {
    "@qrgrid/core": "workspace:*"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "catalog:",
    "@angular/animations": "catalog:",
    "@angular/cli": "catalog:",
    "@angular/common": "catalog:",
    "@angular/compiler": "catalog:",
    "@angular/compiler-cli": "catalog:",
    "@angular/core": "catalog:",
    "@types/jasmine": "catalog:",
    "jasmine-core": "catalog:",
    "karma": "catalog:",
    "karma-chrome-launcher": "catalog:",
    "karma-coverage": "catalog:",
    "karma-jasmine": "catalog:",
    "karma-jasmine-html-reporter": "catalog:",
    "ng-packagr": "^21.2.0",
    "rxjs": "catalog:",
    "tslib": "catalog:",
    "typescript": "catalog:",
    "zone.js": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "/dist"
  ]
}
