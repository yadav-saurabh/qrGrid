{
  "name": "@qrgrid/vue",
  "version": "1.4.5",
  "type": "module",
  "homepage": "https://www.qrgrid.dev/",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "private": false,
  "description": "The Ultimate Customizable QR Code JavaScript Library QR Grid for vue",
  "license": "MIT",
  "bugs": "https://github.com/yadav-saurabh/qrgrid/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/yadav-saurabh/qrgrid",
    "directory": "packages/vue"
  },
  "keywords": [
    "qr",
    "styling",
    "qrgrid",
    "vue",
    "vue3"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./canvas": "./src/canvas/index.ts",
    "./svg": "./src/svg/index.ts"
  },
  "scripts": {
    "build": "rimraf ./dist && vite build && node ../../scripts/build-pkg.mjs",
    "type-check": "vue-tsc --noEmit",
    "tsc:build": "vue-tsc -b"
  },
  "dependencies": {
    "@qrgrid/core": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "^4.5.3",
    "vue-tsc": "catalog:"
  },
  "peerDependencies": {
    "vue": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "/dist"
  ]
}
