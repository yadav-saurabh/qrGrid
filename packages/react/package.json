{
  "name": "@qrgrid/react",
  "version": "1.3.5",
  "type": "module",
  "homepage": "https://www.qrgrid.dev/",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "private": false,
  "description": "The Ultimate Customizable QR Code JavaScript Library QR Grid for react",
  "license": "MIT",
  "bugs": "https://github.com/yadav-saurabh/qrgrid/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/yadav-saurabh/qrgrid",
    "directory": "packages/react"
  },
  "keywords": [
    "qr",
    "qrgrid",
    "styling",
    "react"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./canvas": "./src/canvas/index.ts",
    "./svg": "./src/svg/index.ts"
  },
  "scripts": {
    "build": "rimraf ./dist && rollup -c && node ../../scripts/build-pkg.mjs",
    "type-check": "tsc --noEmit",
    "tsc:build": "tsc -b",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@qrgrid/core": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "typescript-eslint": "catalog:",
    "rimraf": "catalog:",
    "rollup": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "/dist"
  ]
}
