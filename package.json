{
  "name": "qrgrid",
  "description": "javascript qr generator",
  "type": "module",
  "private": false,
  "version": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yadav-saurabh/qrgrid.git"
  },
  "keywords": [
    "qr",
    "nodejs",
    "typescript",
    "react",
    "angular",
    "vue"
  ],
  "author": "yadav-saurabh",
  "scripts": {
    "changeset": "changeset",
    "prune": "turbo prune",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "publish-packages": "turbo run build && changeset version && pnpm install --no-frozen-lockfile && node scripts/publish.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "prettier": "^3.5.3",
    "turbo": "^2.8.11"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "lmdb",
      "msgpackr-extract"
    ],
    "overrides": {
      "esbuild": ">=0.25.0",
      "ajv@>=8": ">=8.18.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-react-hooks>eslint": "^10"
      }
    }
  }
}
